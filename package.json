{
  "name": "antimeridian",
  "version": "1.0.0",
  "description": "Port of the Python gadomski/antimeridian package. Correct GeoJSON geometries that cross the 180th meridian.",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "exports": {
    "import": "./dist/index.esm.js",
    "require": "./dist/index.cjs.js"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "geojson",
    "antimeridian",
    "pole"
  ],
  "author": "Yuki Sasaki <antimeridian@yumem.io>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "rollup": "^4.34.0"
  },
  "jest": {
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  }
}
